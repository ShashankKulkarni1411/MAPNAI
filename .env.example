# ─────────────────────────────────────────────────────────────
#  MAPNAI — Environment Configuration
#  Copy this file to .env and fill in your credentials.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── News APIs ────────────────────────────────────────────────
NEWSAPI_KEY=ed4eea6e1856458f8a122eded6bfc643
GNEWS_API_KEY=737211a8be316b144a88d3740a6a1d0b
NEWSDATA_API_KEY=pub_84c8e0d2d0034ac2a152278186e9e0c0

# ── Bluesky Firehose (zero-auth, zero-cost public stream) ────
BLUESKY_FIREHOSE_URL=wss://bsky.network/xrpc/com.atproto.sync.subscribeRepos
BLUESKY_MAX_POSTS=200

# ── MongoDB (Atlas) ──────────────────────────────────────────
# Replace <db_password> with the mapnaiUser password from MongoDB Atlas
MONGO_URI=mongodb+srv://mapnaiUser:Mapnai%4012345@cluster0.8rhhosm.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=mapnai

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://387a7a7b.databases.neo4j.io
NEO4J_USER=387a7a7b
NEO4J_PASSWORD=qveqAjUckBmFygcZWwoWEtUbhS5Jiszt7YEpev5cPcY

# ── FAISS (local path for index persistence) ─────────────────
FAISS_INDEX_PATH=./data/faiss_index
FAISS_METADATA_PATH=./data/faiss_metadata.pkl

# ── Embedding Model ──────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Ingestion Settings ───────────────────────────────────────
INGESTION_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_SOURCE=50
MIN_ARTICLE_LENGTH=100
REQUEST_TIMEOUT_SECONDS=15
MAX_RETRIES=3

# ── Language ─────────────────────────────────────────────────
PRIMARY_LANGUAGE=en

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/ingestion.log
