# ─────────────────────────────────────────────────────────────
#  MAPNAI — Environment Configuration
#  Copy this file to .env and fill in your credentials.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── News APIs ────────────────────────────────────────────────
NEWSAPI_KEY=apikey
GNEWS_API_KEY=apikey
NEWSDATA_API_KEY=apikey

# ── Bluesky Firehose (zero-auth, zero-cost public stream) ────
BLUESKY_FIREHOSE_URL=url
BLUESKY_MAX_POSTS=req

# ── MongoDB (Atlas) ──────────────────────────────────────────
# Replace <db_password> with the mapnaiUser password from MongoDB Atlas
MONGO_URI=mongodb+srv://user:password@cluster0.8rhhosm.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=password

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=url
NEO4J_USER=user
NEO4J_PASSWORD=pass

# ── FAISS (local path for index persistence) ─────────────────
FAISS_INDEX_PATH=.path
FAISS_METADATA_PATH=path

# ── Embedding Model ──────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Ingestion Settings ───────────────────────────────────────
INGESTION_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_SOURCE=50
MIN_ARTICLE_LENGTH=100
REQUEST_TIMEOUT_SECONDS=15
MAX_RETRIES=3

# ── Language ─────────────────────────────────────────────────
PRIMARY_LANGUAGE=en

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/ingestion.log
